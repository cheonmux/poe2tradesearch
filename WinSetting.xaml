<Window x:Class="Poe2TradeSearch.WinSetting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정" ResizeMode="NoResize" SizeToContent="WidthAndHeight" MinWidth="360" MinHeight="400"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="Malgun Gothic" FontSize="12"
        Loaded="Window_Loaded" PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 섹션 제목 -->
        <TextBlock Grid.Row="0" Text="검색 단축키" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Ctrl+C 자동 감지 -->
        <RadioButton Grid.Row="1" Name="rbAuto" Content="Ctrl+C 자동 감지 (기본)" Margin="0,0,0,8"
                     Checked="rbAuto_Checked"/>

        <!-- 직접 지정 -->
        <RadioButton Grid.Row="2" Name="rbManual" Content="직접 지정:" Margin="0,0,0,8"
                     Checked="rbManual_Checked"/>

        <!-- 키 캡처 영역 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="20,0,0,0">
            <CheckBox Name="ckCtrl" Content="Ctrl +" VerticalAlignment="Center" Margin="0,0,6,0"
                      IsChecked="True" IsEnabled="False"/>
            <Button Name="btnCapture" Width="120" Height="26"
                    Content="키를 누르세요..." IsEnabled="False"
                    Click="btnCapture_Click" Focusable="False"/>
        </StackPanel>

        <!-- 구분선 -->
        <Separator Grid.Row="4" Margin="0,8,0,0"/>

        <!-- 자동 숨김 섹션 -->
        <TextBlock Grid.Row="5" Text="시세 창 자동 숨김" FontWeight="Bold" Margin="0,0,0,10"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="숨김까지 대기(초):" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Name="tbHideDelay" Width="48" Height="22" VerticalContentAlignment="Center"
                     PreviewTextInput="tbHideDelay_PreviewTextInput"/>
            <TextBlock Text="(0 = 자동 숨김 끔)" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="Gray"/>
        </StackPanel>

        <!-- 구분선 -->
        <Separator Grid.Row="7" Margin="0,8,0,0"/>

        <!-- Ctrl+휠 탭 이동 -->
        <CheckBox Grid.Row="8" Name="ckUseCtrlWheel" Content="Ctrl+휠로 창고 탭 이동 (관리자 권한 필요)" Margin="0,0,0,10"/>

        <!-- 리그 선택 섹션 -->
        <TextBlock Grid.Row="9" Text="리그" FontWeight="Bold" Margin="0,0,0,10"/>
        <ComboBox Grid.Row="10" Name="cbLeague" Width="200" Height="26" HorizontalAlignment="Left" Margin="0,0,0,8">
            <ComboBoxItem Content="Runes of Aldur"/>
            <ComboBoxItem Content="HC Runes of Aldur"/>
            <ComboBoxItem Content="Standard"/>
            <ComboBoxItem Content="Hardcore"/>
        </ComboBox>

        <!-- 글자 크기(UI 배율) 섹션 -->
        <TextBlock Grid.Row="11" Text="글자 크기" FontWeight="Bold" Margin="0,10,0,10"/>
        <ComboBox Grid.Row="12" Name="cbUiScale" Width="200" Height="26" HorizontalAlignment="Left" Margin="0,0,0,8">
            <ComboBoxItem Content="100% (기본)" Tag="1.0"/>
            <ComboBoxItem Content="115%" Tag="1.15"/>
            <ComboBoxItem Content="130%" Tag="1.3"/>
            <ComboBoxItem Content="150%" Tag="1.5"/>
        </ComboBox>

        <!-- 게임패드 섹션 -->
        <TextBlock Grid.Row="13" Text="게임패드 (엑박패드 기준)" FontWeight="Bold" Margin="0,10,0,10"/>
        <StackPanel Grid.Row="14" Orientation="Horizontal" Margin="0,0,0,8">
            <CheckBox Name="ckGamePadEnabled" Content="RT + " VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox Name="cbGamePadButton" Width="60" Height="26" IsEnabled="False">
                <ComboBoxItem Content="A"/>
                <ComboBoxItem Content="X"/>
                <ComboBoxItem Content="Y"/>
                <ComboBoxItem Content="B"/>
            </ComboBox>
            <TextBlock Text=" 로 시세 검색" VerticalAlignment="Center" Margin="4,0,0,0"/>
        </StackPanel>

        <!-- 인게임 단축키 섹션 -->
        <TextBlock Grid.Row="15" Text="인게임 단축키" FontWeight="Bold" Margin="0,10,0,10"/>
        <Grid Grid.Row="16" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="은신처 이동:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="0" Grid.Column="1" Name="cbHideoutKey" Width="80" Height="26"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="남은 몬스터 수:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Name="cbRemainingKey" Width="80" Height="26"/>
        </Grid>

        <!-- 배경색 섹션 -->
        <TextBlock Grid.Row="17" Text="배경색" FontWeight="Bold" Margin="0,10,0,10"/>
        <StackPanel Grid.Row="18" Orientation="Horizontal" Margin="0,0,0,8">
            <Border Name="bdColorPreview" Width="24" Height="24" CornerRadius="3" Margin="0,0,8,0" BorderBrush="#AAAAAA" BorderThickness="1"/>
            <TextBox Name="tbBgColor" Width="80" Height="24" VerticalContentAlignment="Center" IsReadOnly="True"/>
            <Button Name="btnPickColor" Content="색상 선택..." Width="80" Height="24" Margin="8,0,0,0" Click="btnPickColor_Click"/>
        </StackPanel>

        <!-- 구분선 -->
        <Separator Grid.Row="19" Margin="0,4,0,0"/>

        <!-- 확인/취소 버튼 -->
        <StackPanel Grid.Row="20" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Name="btnOk" Content="확인" Width="72" Height="26" Margin="0,0,8,0"
                    Click="btnOk_Click"/>
            <Button Name="btnCancel" Content="취소" Width="72" Height="26"
                    Click="btnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
