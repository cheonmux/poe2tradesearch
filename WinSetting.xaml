<Window x:Class="Poe2TradeSearch.WinSetting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정" ResizeMode="NoResize" SizeToContent="WidthAndHeight" MinWidth="360"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="Malgun Gothic" FontSize="12"
        Loaded="Window_Loaded" PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 섹션 제목 -->
        <TextBlock Grid.Row="0" Text="검색 단축키" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Ctrl+C 자동 감지 -->
        <RadioButton Grid.Row="1" Name="rbAuto" Content="Ctrl+C 자동 감지 (기본)" Margin="0,0,0,8"
                     Checked="rbAuto_Checked"/>

        <!-- 직접 지정 -->
        <RadioButton Grid.Row="2" Name="rbManual" Content="직접 지정:" Margin="0,0,0,8"
                     Checked="rbManual_Checked"/>

        <!-- 키 캡처 영역 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="20,0,0,0">
            <CheckBox Name="ckCtrl" Content="Ctrl +" VerticalAlignment="Center" Margin="0,0,6,0"
                      IsChecked="True" IsEnabled="False"/>
            <Button Name="btnCapture" Width="120" Height="26"
                    Content="키를 누르세요..." IsEnabled="False"
                    Click="btnCapture_Click" Focusable="False"/>
        </StackPanel>

        <!-- 구분선 -->
        <Separator Grid.Row="4" Margin="0,8,0,0"/>

        <!-- 자동 숨김 섹션 -->
        <TextBlock Grid.Row="5" Text="시세 창 자동 숨김" FontWeight="Bold" Margin="0,0,0,10"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="숨김까지 대기(초):" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Name="tbHideDelay" Width="48" Height="22" VerticalContentAlignment="Center"
                     PreviewTextInput="tbHideDelay_PreviewTextInput"/>
            <TextBlock Text="(0 = 자동 숨김 끔)" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="Gray"/>
        </StackPanel>

        <!-- 구분선 -->
        <Separator Grid.Row="7" Margin="0,8,0,0"/>

        <!-- Ctrl+휠 탭 이동 -->
        <CheckBox Grid.Row="8" Name="ckUseCtrlWheel" Content="Ctrl+휠로 창고 탭 이동 (관리자 권한 필요)" Margin="0,0,0,10"/>

        <!-- 리그 선택 섹션 -->
        <TextBlock Grid.Row="9" Text="리그" FontWeight="Bold" Margin="0,0,0,10"/>
        <ComboBox Grid.Row="10" Name="cbLeague" Width="200" Height="26" HorizontalAlignment="Left" Margin="0,0,0,8">
            <ComboBoxItem Content="Runes of Aldur"/>
            <ComboBoxItem Content="HC Runes of Aldur"/>
            <ComboBoxItem Content="Standard"/>
            <ComboBoxItem Content="Hardcore"/>
        </ComboBox>

        <!-- 구분선 -->
        <Separator Grid.Row="10" Margin="0,4,0,0"/>

        <!-- 확인/취소 버튼 -->
        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Name="btnOk" Content="확인" Width="72" Height="26" Margin="0,0,8,0"
                    Click="btnOk_Click"/>
            <Button Name="btnCancel" Content="취소" Width="72" Height="26"
                    Click="btnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
